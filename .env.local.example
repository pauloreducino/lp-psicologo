# ─── WordPress API ───────────────────────────────
# URL base da REST API do seu WordPress
# Desenvolvimento local (Local by Flywheel):
WORDPRESS_API_URL=http://rafaelmendes.great-site.net/wp-json/wp/v2

# Produção (substitua pelo seu domínio real):
# WORDPRESS_API_URL=https://cms.drrafaelmendes.com.br/wp-json/wp/v2

# ─── Revalidação (Webhook) ────────────────────────
# Chave secreta para o webhook do WordPress revalidar o Next.js
# Gere uma chave forte: use letras, números e símbolos
REVALIDATE_SECRET=troque_por_uma_chave_secreta_forte_aqui_2024

# ─── (Opcional) URL do site em produção ──────────
NEXT_PUBLIC_SITE_URL=https://drrafaelmendes.com.br
